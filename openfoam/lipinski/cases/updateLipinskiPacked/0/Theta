FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Theta;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions          [0 2 -2 0 0 0 0];

internalField   uniform 0.0;

boundaryField
{
    INLET
    {
        type            fixedValue;
        value           uniform 1.0e-7;
    }

    OUTLET
    {
        type            inletOutlet;
        inletValue      uniform 1.0e-7;
        value           uniform 1.0e-7;
    }

    WALL
    {
        type            zeroGradient;
    }

    defaultFaces
    {
        type            empty;
    }
}


